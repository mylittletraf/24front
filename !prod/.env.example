# Production environment for the frontend !prod bundle (runtime config only).
# Copy to .env (gitignored) and fill in real values, then run scripts/init-server.sh
# (first time) or scripts/deploy.sh (updates). Compose reads this file both as
# env_file for the container and for ${VAR} interpolation in docker-compose.yml.
#
# NOTE: the site's public identity (NEXT_PUBLIC_*: site URL, brand, analytics,
# verification) is NOT here — it's inlined into the image at build time on the
# build host (repo-root .env.build / build.sh). Only server-side runtime config
# that can change per deploy lives below.

# --- Image ----------------------------------------------------------------------
# Tag pulled from registry.cpapony.com/frontend24. Keep `latest`, or pin a specific
# build (short git SHA printed by build.sh at the repo root) to deploy / roll back.
FRONTEND_TAG=latest

# --- Server runtime -------------------------------------------------------------
# API origin the SSR server fetches from (server-to-server). Use the same value
# that was baked at build time (it also fixed the sitemap/robots rewrites).
API_INTERNAL_URL=https://backend.example.com/api/v1

# SSRF allow-list for the /media proxy: CSV of host[:port] permitted as private/
# loopback targets. Leave empty in prod — public signed storage URLs need no entry.
MEDIA_INTERNAL_HOSTS=

# --- Edge (reuses the backend's nginx-proxy + Let's Encrypt on this host) --------
# DOMAIN — public hostname (becomes VIRTUAL_HOST / LETSENCRYPT_HOST).
# ACME_EMAIL — contact for Let's Encrypt issuance/expiry notices.
DOMAIN=example.com
ACME_EMAIL=admin@example.com
