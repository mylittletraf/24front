# Public base URL of this frontend (used for canonical fallback, quick-login links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site brand name + default description (header, footer, page titles, metadata)
NEXT_PUBLIC_SITE_NAME=24front
NEXT_PUBLIC_SITE_DESCRIPTION=Tube site

# Backend API base. Public reads from Server Components use the internal URL;
# the browser/client uses the public one (can be the same in dev).
API_INTERNAL_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Default content language (?lang fallback)
NEXT_PUBLIC_DEFAULT_LANG=ru

# Media proxy: /media/* is served by a dynamic route that forwards to whatever storage host the
# API returned, so any number of external storage hosts work with no per-host config. Public hosts
# are allowed automatically; private/loopback hosts are blocked unless listed here (comma-separated;
# a bare domain matches its subdomains). Local dev storage runs on localhost:8000.
MEDIA_INTERNAL_HOSTS=localhost:8000

# Analytics (optional, left empty in dev)
NEXT_PUBLIC_GA_ID=          # Google Analytics 4 measurement ID, e.g. G-XXXXXXX
NEXT_PUBLIC_YM_ID=          # Yandex.Metrica counter number, e.g. 99999999
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Site-ownership verification tokens (token only, not the whole meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=   # Google Search Console → HTML tag method
NEXT_PUBLIC_YANDEX_VERIFICATION=        # Yandex Webmaster → Meta tag method

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
