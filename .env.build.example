# Build-time public config for the frontend image (used by build.sh on the BUILD host).
# Copy to .env.build (gitignored) and fill in real values for THIS production site.
#
# Why build-time: Next.js inlines NEXT_PUBLIC_* into the client bundle at `next build`,
# so they can't be changed at runtime. They're site-identity constants (URL, brand,
# analytics, verification) — stable for this one prod site — so the image carries them.
# The browser → API path is NOT here: it goes through the same-origin /api/proxy at
# runtime, so it follows whatever domain the image is served on.
#
# Anything left blank falls back to the app's built-in defaults (src/lib/api/config.ts).

# Public origin of the frontend (canonical/OG/hreflang URLs).
NEXT_PUBLIC_SITE_URL=https://example.com
# Brand name + default description (header/footer/titles/metadata fallback).
NEXT_PUBLIC_SITE_NAME=24front
NEXT_PUBLIC_SITE_DESCRIPTION=Tube site
# Default content language (falls back when there's no ?lang and no cookie).
NEXT_PUBLIC_DEFAULT_LANG=ru
# 18+ markup (isFamilyFriendly:false, age-restriction meta). Set false to drop it.
NEXT_PUBLIC_ADULT_CONTENT=true

# Browser API base — currently unused (the browser uses the same-origin /api/proxy),
# kept for completeness/forward-compat. Safe to leave as the public API origin.
NEXT_PUBLIC_API_URL=https://example.com/api/v1

# API origin the SERVER renders against AND the build-time source for the
# sitemap/robots rewrites baked into next.config.ts. Set the same value at runtime
# in !prod/.env (API_INTERNAL_URL).
API_INTERNAL_URL=https://backend.example.com/api/v1

# --- Analytics / verification / monitoring (all optional; blank = omitted) -------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_SENTRY_DSN=
